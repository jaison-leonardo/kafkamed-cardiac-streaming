# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=heart-records
KAFKA_NUM_PARTITIONS=1

# ── Producer ─────────────────────────────────────────────────────────────────
PRODUCER_INTERVAL_SECONDS=2
PRODUCER_CSV_PATH=/data/heart.csv
PRODUCER_LOOP=true

# ── Spark Consumer ────────────────────────────────────────────────────────────
SPARK_APP_NAME=KafkaMedConsumer
SPARK_CHECKPOINT_PATH=/checkpoints/spark-consumer
SPARK_TRIGGER_SECONDS=5
MODEL_PATH=/artifacts/heart_pipeline.pkl
FEATURE_COLUMNS_PATH=/artifacts/feature_columns.json

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/
MONGO_DB=kafkamed
MONGO_COLLECTION=predictions

# ── Flask API ─────────────────────────────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=false
